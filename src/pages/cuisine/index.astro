---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import EmailCapture from '../../components/EmailCapture.astro';
import FAQ from '../../components/FAQ.astro';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Lao Cuisine Guide', url: '/cuisine/' },
];

const pageTitle = 'Lao Cuisine Guide — Eat Your Way Across Laos';
const pageDescription = 'A region-by-region guide to Lao cuisine — from sticky rice and laap to Mekong grilled fish and Bolaven coffee. Find where to eat the real thing across 9 destinations.';

interface Dish {
  name: string;
  image?: string;
  destination: string;
  slug: string;
  price: string;
  description: string;
  tag?: string;
}

interface MenuSection {
  region: string;
  tagline: string;
  gradient: string;
  dishes: Dish[];
}

const menu: MenuSection[] = [
  {
    region: 'Northern Laos',
    tagline: 'Luang Prabang\'s refined royal cuisine, mountain herbs, and the flavors of the northern highlands',
    gradient: 'linear-gradient(135deg, #0D7377 0%, #4DB6AC 100%)',
    dishes: [
      {
        name: 'Khao Piak Sen',
        image: '/images/cuisine/khao-piak-sen.jpg',
        destination: 'Luang Prabang',
        slug: 'luang-prabang',
        price: '₭20,000–40,000 / $1–2 USD',
        description: 'Lao rice noodle soup with a slightly thick, starchy broth — the comfort food of Luang Prabang. Hand-rolled noodles in chicken or pork stock, topped with fresh herbs and a squeeze of lime. Found at every morning market stall.',
        tag: 'Iconic',
      },
      {
        name: 'Or Lam',
        image: '/images/cuisine/or-lam.jpg',
        destination: 'Luang Prabang',
        slug: 'luang-prabang',
        price: '₭30,000–60,000 / $1.50–3 USD',
        description: 'Luang Prabang\'s signature stew — a slow-cooked mix of Lao eggplant, dill, dried buffalo skin, chilies, and sakhan (a woody Lao pepper). The flavors are layered and deeply earthy. A dish that exists nowhere else in the world quite like this.',
        tag: 'Heritage',
      },
      {
        name: 'Khao Jee',
        image: '/images/cuisine/khao-jee.jpg',
        destination: 'Nong Khiaw',
        slug: 'nong-khiaw',
        price: '₭5,000–10,000 / $0.25–0.50 USD',
        description: 'Sticky rice patties grilled over charcoal and brushed with egg — a simple, smoky street snack sold from roadside vendors across the northern mountains. Cheap, filling, and perfect for breakfast on the go.',
      },
      {
        name: 'Jaew Bong',
        image: '/images/cuisine/jaew-bong.jpg',
        destination: 'Luang Prabang',
        slug: 'luang-prabang',
        price: '₭15,000–30,000 / $0.75–1.50 USD',
        description: 'A thick, spicy condiment made from roasted chilies, dried buffalo skin, galangal, and shallots — pounded in a mortar and served as a dip with sticky rice and fresh vegetables. Intensely savory with a slow-building heat.',
      },
      {
        name: 'Sai Oua',
        image: '/images/cuisine/sai-oua.jpg',
        destination: 'Luang Prabang',
        slug: 'luang-prabang',
        price: '₭20,000–40,000 / $1–2 USD',
        description: 'Lao herb sausage packed with lemongrass, galangal, kaffir lime leaf, dill, and chilies — grilled until the casing crisps. Every market in Luang Prabang has a vendor spiraling them over charcoal.',
        tag: 'Must-Try',
      },
    ],
  },
  {
    region: 'Central Laos',
    tagline: 'Vientiane street food, Mekong river flavors, and the heart of everyday Lao cooking',
    gradient: 'linear-gradient(135deg, #BF360C 0%, #E8654A 100%)',
    dishes: [
      {
        name: 'Laap',
        image: '/images/cuisine/laap.jpg',
        destination: 'Vientiane',
        slug: 'vientiane',
        price: '₭25,000–50,000 / $1.25–2.50 USD',
        description: 'The national dish of Laos — minced meat (pork, chicken, duck, or fish) tossed with toasted rice powder, fish sauce, lime juice, mint, and chilies. Eaten with sticky rice and fresh vegetables. Every Lao family has their own version.',
        tag: 'National Dish',
      },
      {
        name: 'Tam Mak Hoong',
        image: '/images/cuisine/tam-mak-hoong.jpg',
        destination: 'Vientiane',
        slug: 'vientiane',
        price: '₭15,000–30,000 / $0.75–1.50 USD',
        description: 'Lao spicy green papaya salad — shredded papaya pounded in a mortar with padaek (fermented fish paste), lime, chilies, tomatoes, and crab paste. Funkier and more intense than the Thai version. A Vientiane street food staple.',
        tag: 'Iconic',
      },
      {
        name: 'Ping Kai',
        image: '/images/cuisine/ping-kai.jpg',
        destination: 'Vang Vieng',
        slug: 'vang-vieng',
        price: '₭30,000–50,000 / $1.50–2.50 USD',
        description: 'Whole chicken marinated in lemongrass, garlic, turmeric, and fish sauce, then grilled slowly over low charcoal. The skin turns golden and crispy while the meat stays juicy. Sold from roadside stalls along every main road.',
      },
      {
        name: 'Khao Niew',
        image: '/images/cuisine/khao-niew.jpg',
        destination: 'Thakhek',
        slug: 'thakhek',
        price: '₭5,000–10,000 / $0.25–0.50 USD',
        description: 'Sticky rice — the staple of every Lao meal. Steamed in a cone-shaped bamboo basket, served in small woven containers called tip khao. You tear off a ball with your fingers and use it to scoop up everything else on the table.',
        tag: 'Essential',
      },
      {
        name: 'Mok Pa',
        image: '/images/cuisine/mok-pa.jpg',
        destination: 'Vang Vieng',
        slug: 'vang-vieng',
        price: '₭30,000–50,000 / $1.50–2.50 USD',
        description: 'Fish steamed inside a banana leaf packet with dill, green onion, galangal, and kaffir lime leaf. The banana leaf locks in moisture and imparts a faint sweetness. Unwrapping the parcel at the table is half the experience.',
        tag: 'Must-Try',
      },
      {
        name: 'Khao Poun',
        image: '/images/cuisine/khao-poun.jpg',
        destination: 'Vientiane',
        slug: 'vientiane',
        price: '₭20,000–40,000 / $1–2 USD',
        description: 'Lao vermicelli soup with a rich coconut curry broth — fragrant with lemongrass, galangal, and turmeric. Served with a mountain of fresh herbs, bean sprouts, and long beans on the side. A morning market favorite in Vientiane.',
      },
    ],
  },
  {
    region: 'Southern Laos',
    tagline: 'Bolaven Plateau coffee, fresh Mekong fish, and the laid-back cuisine of 4,000 Islands',
    gradient: 'linear-gradient(135deg, #1A2332 0%, #6A1B9A 50%, #D4A853 100%)',
    dishes: [
      {
        name: 'Pho Lao',
        image: '/images/cuisine/pho-lao.jpg',
        destination: 'Pakse',
        slug: 'pakse',
        price: '₭20,000–40,000 / $1–2 USD',
        description: 'Lao-style rice noodle soup with a clear, aromatic broth — lighter and herbier than its Vietnamese cousin. Served with a plate of fresh greens, bean sprouts, and chili sauce. The standard breakfast across southern Laos.',
      },
      {
        name: 'Lao Coffee',
        image: '/images/cuisine/lao-coffee.jpg',
        destination: 'Bolaven Plateau',
        slug: 'bolaven-plateau',
        price: '₭10,000–20,000 / $0.50–1 USD',
        description: 'Strong drip coffee from Bolaven Plateau beans, brewed through a cloth filter and served in a glass with a thick layer of condensed milk at the bottom. Rich, smooth, and intensely sweet. One of Southeast Asia\'s best-kept coffee secrets.',
        tag: 'Legendary',
      },
      {
        name: 'Ping Pa',
        image: '/images/cuisine/ping-pa.jpg',
        destination: '4000 Islands',
        slug: '4000-islands',
        price: '₭40,000–80,000 / $2–4 USD',
        description: 'Whole Mekong fish stuffed with lemongrass and herbs, grilled over charcoal until the skin chars and the flesh flakes. Best eaten on the banks of the Mekong in Don Det or Don Khon, pulled straight from the river that morning.',
        tag: 'Fresh Catch',
      },
      {
        name: 'Khai Paen',
        image: '/images/cuisine/khai-paen.jpg',
        destination: 'Luang Prabang',
        slug: 'luang-prabang',
        price: '₭15,000–25,000 / $0.75–1.25 USD',
        description: 'Sheets of Mekong river weed dried with sesame seeds and tomato, then deep-fried until crispy. A uniquely Lao snack — crunchy, nutty, and unlike anything else you have eaten. Served with jaew bong dipping sauce.',
        tag: 'Rare',
      },
      {
        name: 'Khao Lam',
        image: '/images/cuisine/khao-lam.jpg',
        destination: 'Phonsavan',
        slug: 'phonsavan',
        price: '₭10,000–20,000 / $0.50–1 USD',
        description: 'Sticky rice mixed with coconut milk and black beans, stuffed inside a bamboo tube and roasted over coals. The bamboo imparts a smoky, woody sweetness. Sold at bus stations and roadside stalls across the Xieng Khouang plateau.',
      },
    ],
  },
];
---
<BaseLayout
  title={pageTitle}
  description={pageDescription}
  pageType="destination"
  schemaData={{ title: pageTitle, description: pageDescription }}
  breadcrumbs={breadcrumbs}
>
  <!-- Hero -->
  <header class="menu-hero">
    <video class="menu-hero-video" autoplay muted loop playsinline preload="metadata">
      <source src="/videos/pillar/cuisine-hero.mp4" type="video/mp4" />
    </video>
    <div class="menu-hero-gradient"></div>
    <div class="menu-hero-noise"></div>
    <div class="menu-hero-content">
      <h1 class="menu-hero-title">The Lao Menu</h1>
      <p class="menu-hero-subtitle">Sticky rice torn by hand, laap pounded in a mortar, Mekong fish grilled over charcoal, and Bolaven coffee dripped through cloth — eat your way across three regions and discover the dishes that define Laos.</p>
      <div class="menu-hero-meta">
        <div class="menu-hero-meta-item">
          <span class="menu-hero-meta-label">Dishes</span>
          <span class="menu-hero-meta-value">17</span>
        </div>
        <div class="menu-hero-meta-item">
          <span class="menu-hero-meta-label">Regions</span>
          <span class="menu-hero-meta-value">3</span>
        </div>
        <div class="menu-hero-meta-item">
          <span class="menu-hero-meta-label">Destinations</span>
          <span class="menu-hero-meta-value">9</span>
        </div>
      </div>
    </div>
    <div class="menu-scroll-hint">Scroll<br />&#8595;</div>
  </header>

  <!-- Breadcrumb -->
  <div class="container-content">
    <Breadcrumb items={breadcrumbs} />
  </div>

  <!-- Personal intro -->
  <section class="menu-personal reveal">
    <div class="container-content">
      <blockquote class="menu-personal-quote">
        <p>I didn't know what to expect from Lao food before my first trip. Then I sat cross-legged on the floor of a Luang Prabang guesthouse and someone handed me a sticky rice basket. You tear off a small ball, press it flat with your thumb, and use it to scoop up everything — the laap, the jaew bong, the grilled fish. No fork needed. I spent the next morning at the Luang Prabang morning market watching women pound papaya salad to order and ladle bowls of khao piak sen from steaming pots. That was the moment I understood: in Laos, the food is the journey.</p>
        <cite>— Scott</cite>
      </blockquote>
    </div>
  </section>

  <!-- Menu Intro -->
  <section class="menu-intro reveal">
    <div class="container-content">
      <div class="menu-intro-card">
        <p class="menu-intro-text">Think of this as your tasting menu for Laos. I have organized the country's essential dishes by region — <strong>Northern Laos</strong> for Luang Prabang's refined mountain cuisine, <strong>Central Laos</strong> for Vientiane's street food and Mekong flavors, and <strong>Southern Laos</strong> for Bolaven coffee and river fish. Click any dish to explore the destination where it's famous.</p>
        <div class="menu-intro-legend">
          <span class="menu-tag menu-tag--nationaldish">National Dish</span>
          <span class="menu-tag menu-tag--iconic">Iconic</span>
          <span class="menu-tag menu-tag--heritage">Heritage</span>
          <span class="menu-tag menu-tag--musttry">Must-Try</span>
          <span class="menu-tag menu-tag--essential">Essential</span>
          <span class="menu-tag menu-tag--legendary">Legendary</span>
          <span class="menu-tag menu-tag--freshcatch">Fresh Catch</span>
          <span class="menu-tag menu-tag--rare">Rare</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Menu Sections by Region -->
  {menu.map((section) => (
    <section class="menu-region reveal">
      <div class="container-content">
        <div class="menu-region-header" style={`background: ${section.gradient};`}>
          <div class="menu-region-header-inner">
            <h2 class="menu-region-name">{section.region}</h2>
            <p class="menu-region-tagline">{section.tagline}</p>
            <span class="menu-region-count">{section.dishes.length} dishes</span>
          </div>
          <div class="menu-region-ornament">&#9733;</div>
        </div>

        <div class="menu-dish-grid">
          {section.dishes.map((dish) => (
            <a href={`/destinations/${dish.slug}/`} class="menu-dish-card">
              <div class="menu-dish-media" style={`background: ${section.gradient};`}>
                {dish.image && (
                  <img src={dish.image} alt={`${dish.name} — ${dish.destination}`} class="menu-dish-img" loading="lazy" />
                )}
                {dish.tag && (
                  <span class={`menu-tag menu-tag--${dish.tag.toLowerCase().replace(/[^a-z]/g, '')}`}>{dish.tag}</span>
                )}
              </div>
              <div class="menu-dish-body">
                <div class="menu-dish-top">
                  <h3 class="menu-dish-name">{dish.name}</h3>
                  <span class="menu-dish-price">{dish.price}</span>
                </div>
                <p class="menu-dish-destination">{dish.destination}</p>
                <p class="menu-dish-desc">{dish.description}</p>
                <span class="menu-dish-cta">Explore {dish.destination} &rarr;</span>
              </div>
              <div class="menu-dish-overlay">
                <p class="menu-dish-overlay-desc">{dish.description}</p>
                <span class="menu-dish-overlay-cta">Explore {dish.destination} &rarr;</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  ))}

  <!-- Bottom CTA -->
  <section class="menu-cta-section reveal">
    <div class="container-content">
      <div class="menu-cta-card">
        <h2 class="menu-cta-heading">Plan Your Food Trip</h2>
        <p class="menu-cta-text">Tell our AI planner which dishes you want to try and it will build a region-by-region itinerary — with the best restaurants, markets, and street food stops.</p>
        <a href="/plan/" class="menu-cta-button">Start Planning &rarr;</a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <FAQ items={[
    { question: "What is the national dish of Laos?", answer: "Laap (also spelled larb) is the national dish of Laos — minced meat tossed with toasted rice powder, fish sauce, lime juice, fresh mint, and chilies. It can be made with pork, chicken, duck, fish, or beef. Every region and family has their own version. Laap is always eaten with sticky rice and represents the communal, hands-on approach to Lao dining." },
    { question: "Is Lao food spicy?", answer: "Yes, Lao food can be quite spicy — chilies are a core ingredient in dishes like tam mak hoong (papaya salad) and jaew bong (chili dip). However, heat is usually customizable. Most dishes are served with fresh herbs, vegetables, and sticky rice that balance the spice. If you are sensitive to heat, ask for 'boh pet' (not spicy) and the cook will adjust. Condiments like chili paste and fresh chilies are typically served on the side." },
    { question: "What are the must-try street foods in Laos?", answer: "Khao jee (grilled sticky rice with egg), tam mak hoong (spicy papaya salad pounded to order), ping kai (grilled lemongrass chicken), sai oua (herb sausage), and khao lam (sticky rice roasted in bamboo). Morning markets are the best place to try everything in one stop. Luang Prabang's morning market and Vientiane's Talat Sao are excellent starting points. Street food typically costs ₭5,000–30,000 ($0.25–1.50 USD) per item." },
    { question: "How much does a meal cost in Laos?", answer: "Street food: ₭10,000–30,000 ($0.50–1.50 USD) per dish. Local noodle shops and beer restaurants: ₭30,000–60,000 ($1.50–3 USD). Mid-range restaurants: ₭50,000–150,000 ($2.50–7.50 USD). Upscale dining in Luang Prabang or Vientiane: ₭150,000–400,000 ($7.50–20 USD). A daily food budget of ₭100,000–200,000 ($5–10 USD) covers three meals comfortably in most destinations." },
    { question: "Is it safe to eat street food in Laos?", answer: "Yes, street food in Laos is generally safe if you follow basic precautions: eat at busy stalls with high turnover (food is fresher), choose items cooked in front of you rather than pre-made, and stick to stalls where locals are eating. Avoid raw vegetables if you have a sensitive stomach, and drink bottled or boiled water only. Lao people eat street food daily — the busier the stall, the safer the food." },
    { question: "What is sticky rice and how is it eaten?", answer: "Sticky rice (khao niew) is the staple food of Laos — the country consumes more sticky rice per capita than anywhere else in the world. It is steamed in a cone-shaped bamboo basket and served in a small woven container called a tip khao. You tear off a small ball with your fingers, press it flat, and use it to scoop up other dishes like laap, jaew, or grilled meats. It accompanies virtually every meal and is the foundation of Lao cuisine." },
  ]} />

  <!-- Email Capture -->
  <div class="container-content reveal" style="padding-bottom: var(--space-6);">
    <EmailCapture
      leadMagnet="Get Our Free Lao Food Guide"
      description="A region-by-region PDF guide to Lao cuisine — with the best morning markets, street food stalls, and dishes you cannot miss."
      bullets={[
        'All 17 dishes with where to find the best version across 9 destinations',
        'Price guide — from ₭5,000 street snacks to ₭150,000 restaurant meals',
        'Food safety tips and dietary considerations for Laos',
        'Printable Lao food phrase card with pronunciation guide',
      ]}
      guideTag="pillar-cuisine"
    />
  </div>

  <!-- Cross-links -->
  <section class="menu-crosslinks reveal">
    <div class="container-content">
      <h3 class="menu-crosslinks-heading">Explore More</h3>
      <div class="menu-crosslinks-grid">
        <a href="/festivals/" class="menu-crosslink-card">
          <span class="menu-crosslink-icon">&#127914;</span>
          <span class="menu-crosslink-label">Festival Calendar</span>
          <span class="menu-crosslink-desc">Lao festivals across 9 destinations, month by month</span>
        </a>
        <a href="/history/" class="menu-crosslink-card">
          <span class="menu-crosslink-icon">&#127963;</span>
          <span class="menu-crosslink-label">History &amp; Heritage</span>
          <span class="menu-crosslink-desc">Temples, colonial traces, and the story behind the land</span>
        </a>
        <a href="/destinations/" class="menu-crosslink-card">
          <span class="menu-crosslink-icon">&#127965;</span>
          <span class="menu-crosslink-label">All Destinations</span>
          <span class="menu-crosslink-desc">Every destination we have explored with honest reviews</span>
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<!-- Scroll Reveal Observer -->
<script>
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const revealObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('visible');
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
    );
    document.querySelectorAll('.reveal').forEach((el) => revealObserver.observe(el));
  } else {
    document.querySelectorAll('.reveal').forEach((el) => el.classList.add('visible'));
  }
</script>

<style>
  /* ================================================================
     HERO — Warm, food-inspired gradient
     ================================================================ */
  .menu-hero {
    position: relative;
    min-height: 60vh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 5rem var(--space-6) 60px;
    overflow: hidden;
  }

  .menu-hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .menu-hero-gradient {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(to bottom, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.15) 40%, rgba(0,0,0,0.55) 100%);
  }

  .menu-hero-noise {
    position: absolute;
    inset: 0;
    z-index: 2;
    background: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E");
    pointer-events: none;
  }

  .menu-hero-content {
    position: relative;
    z-index: 3;
    max-width: 720px;
  }

  .menu-hero-title {
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: var(--weight-bold);
    color: #fff;
    line-height: 1.1;
    margin: 0 0 var(--space-3);
  }

  .menu-hero-subtitle {
    font-size: clamp(1rem, 2vw, 1.15rem);
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.6;
    margin: 0 0 var(--space-5);
    max-width: 580px;
  }

  .menu-hero-meta {
    display: flex;
    gap: var(--space-5);
    flex-wrap: wrap;
  }

  .menu-hero-meta-item {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .menu-hero-meta-label {
    font-size: 0.65rem;
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.5);
  }

  .menu-hero-meta-value {
    font-size: 1.1rem;
    font-weight: var(--weight-bold);
    color: #fff;
  }

  .menu-scroll-hint {
    position: absolute;
    bottom: 16px;
    right: var(--space-6);
    z-index: 3;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgba(255, 255, 255, 0.35);
    text-align: center;
    animation: menuBounce 2s ease-in-out infinite;
  }

  @keyframes menuBounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(6px); }
  }

  /* ================================================================
     MENU INTRO
     ================================================================ */
  .menu-intro {
    padding: var(--space-8) 0 var(--space-4);
  }

  .menu-intro-card {
    background: var(--color-white);
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 16px;
    padding: var(--space-5) var(--space-6);
    text-align: center;
  }

  .menu-intro-text {
    font-size: 1rem;
    color: var(--color-slate);
    line-height: 1.7;
    max-width: 640px;
    margin: 0 auto var(--space-4);
  }

  .menu-intro-legend {
    display: flex;
    justify-content: center;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  /* ================================================================
     TAGS
     ================================================================ */
  .menu-tag {
    display: inline-block;
    font-size: 0.6rem;
    font-weight: var(--weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 3px 8px;
    border-radius: 6px;
    line-height: 1.4;
  }

  .menu-tag--heritage {
    background: rgba(191, 54, 12, 0.1);
    color: #BF360C;
  }

  .menu-tag--musttry, .menu-tag--mustry {
    background: rgba(13, 115, 119, 0.1);
    color: var(--color-ocean-teal);
  }

  .menu-tag--iconic {
    background: rgba(212, 168, 83, 0.15);
    color: #9A7B2E;
  }

  .menu-tag--freshcatch {
    background: rgba(33, 150, 243, 0.1);
    color: #1565C0;
  }

  .menu-tag--rare {
    background: rgba(106, 27, 154, 0.1);
    color: #6A1B9A;
  }

  .menu-tag--pasalubong {
    background: rgba(232, 101, 74, 0.1);
